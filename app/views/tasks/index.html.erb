<p style="color: green"><%= notice %></p>

<% content_for :title, "Tasks" %>

<h1>Tasks</h1>

<table>
  <tr>
    <th>ID</th>
    <th>Name</th>
    <th>Budget</th>
    <th>Deadline</th>
    <th>Order</th>
    <th>Controls</th>
  </tr>
  <% @tasks.each do |task| %>
    <tr id="<%= dom_id task %>">
      <%= render task %>
      <td>
        <%= link_to "Ver mais", task %>
      </td>
    </tr>
  <% end %>
</table>

<style>
table, th, td {
  border: 1px solid black;
  border-collapse: collapse;
}
</style>

<%= link_to "New task", new_task_path %>
