<p style="color: green"><%= notice %></p>

<% content_for :title, "Tasks" %>

<h1>Tasks</h1>


<table>
  <tr>
    <th>ID</th>
    <th>Name</th>
    <th>Budget</th>
    <th>Deadline</th>
    <th>Order</th>
    <th>Controls</th>
  </tr>
  <% @tasks.each do |task| %>
    <tr id="<%= dom_id task %>">
      <%= render task %>
      <td>
        <%= link_to "Ver mais", task %>
      </td>
    </tr>
  <% end %>
  <tr>
    <%= form_with model: @task, url: "/tasks", method: :post, local: true do |form| %>
      <td>
      </td>
      <td>
        <%= form.text_field :name %>
      </td>
      <td>
        <%= form.number_field :budget %>
      </td>
      <td>
        <%= form.date_field :deadline %>
      </td>
      <td>
        <%= form.number_field :order %>
      </td>
      <td>
        <%= form.submit "Create Task", input_field_name: nil %>
      </td>
    <% end %>
  </tr>
</table>




<style>
table, th, td {
  border: 1px solid black;
  border-collapse: collapse;
}
</style>



<%= link_to "New task", new_task_path %>
