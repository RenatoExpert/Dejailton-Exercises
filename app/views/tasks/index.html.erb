<p style="color: green"><%= notice %></p>

<% content_for :title, "Tasks" %>

<h1>Tasks</h1>

<div id="tasks">
  <% @tasks.each do |task| %>
    <%= render task %>
    <p>
      <%= link_to "Show this task", task %>
    </p>
  <% end %>
</div>

<table>
  <tr>
    <th>ID</th>
    <th>Name</th>
    <th>Budget</th>
    <th>Deadline</th>
    <th>Order</th>
  </tr>
  <tr>
  </tr>
</table>


<%= link_to "New task", new_task_path %>
